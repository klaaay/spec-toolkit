{
  "name": "@klaaay/uno-config",
  "version": "2.4.0",
  "license": "MIT",
  "type": "module",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "nr build",
    "copy-style": "cpx \"src/styles/**/*\" dist/styles",
    "dev": "tsup --watch",
    "build-tsup": "tsup",
    "build": "rimraf dist && pnpm run build-tsup && pnpm run copy-style && echo 'Successfully built'"
  },
  "devDependencies": {
    "@types/node": "^18.14.1",
    "cpx": "^1.5.0",
    "rimraf": "^6.0.1"
  },
  "peerDependencies": {
    "unocss": "^66.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
